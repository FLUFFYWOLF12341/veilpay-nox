{
  "name": "veilpay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "hardhat test test/VeilPay.test.ts",
    "test:nox": "NOX_INTEGRATION=1 hardhat test test/VeilPay.test.ts",
    "verify": "npm test && npm run typecheck && npm run lint && npm run build && npm run test:nox",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "postinstall": "node scripts/patch-nox-plugin.mjs"
  },
  "dependencies": {
    "@iexec-nox/handle": "0.1.0-beta.13",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "viem": "^2.37.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@iexec-nox/nox-hardhat-plugin": "0.1.0",
    "@iexec-nox/nox-protocol-contracts": "0.2.4",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "hardhat": "3.9.1",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
